  async def test_call_websocket(uri: str, session_id: str):
      """
      Test real-time conversation via WebSocket

      Args:
          uri: WebSocket URI (e.g., ws://localhost:8000/ws/call/test-session)
          session_id: Session identifier
      """

      print(f"\n{'='*70}")
      print(f"\U0001f3a4 Breezi WebSocket Call Test")
      print(f"{'='*70}")
      print(f"\U0001f4cd Connecting to: {uri}")
      print(f"\U0001f194 Session ID: {session_id}")
      print(f"\U0001f4a1 Type 'exit' or 'quit' to end the call")
      print(f"{'='*70}\n")

      try:
          async with websockets.connect(uri) as websocket:
              print("\u2705 Connected to server\\n")

              # Receive initial greeting
              message = await websocket.recv()
              data = json.loads(message)
              if data.get("type") == "greeting":
                  print(f"\U0001f916 {data.get('message')}\\n")

              turn_count = 0

              # Conversation loop
              while True:
                  # Get user input
                  user_input = input("\U0001f464 You: ").strip()

                  if not user_input:
                      print("\u26a0\ufe0f  Please enter something...\\n")
                      continue

                  if user_input.lower() in ["exit", "quit"]:
                      print("\\n\U0001f44b Ending call...")
                      await websocket.send(json.dumps({"type": "end"}))
                      break

                  turn_count += 1

                  # Send message
                  await websocket.send(json.dumps({
                      "type": "text",
                      "message": user_input,
                  }))

                  # Receive response
                  response_msg = await websocket.recv()
                  response_data = json.loads(response_msg)

                  # Display response
                  if response_data.get("type") == "response":
                      print(f"\\n\U0001f916 Breezi: {response_data.get('message')}\\n")

                      # Display state if available
                      state = response_data.get("state", {})
                      if state:
                          print(f"\U0001f4ca State Update:")
                          print(f"   Intent: {state.get('intent')}")
                          print(f"   Slots: {state.get('slots')}")
                          if state.get('missing_slots'):
                              print(f"   \u23f3 Still waiting for: {', '.join(state.get('missing_slots'))}")
                          print()

                  elif response_data.get("type") == "error":
                      print(f"\\n\u274c Error: {response_data.get('message')}\\n")

              print(f"\\n\u2705 Call ended. Total turns: {turn_count}")

      except ConnectionRefusedError:
          print(f"\u274c Connection refused. Make sure server is running at {uri}")
          print("\\n\U0001f4a1 Start server with: docker-compose -f docker-compose.mock.yml up -d")
          sys.exit(1)

      except Exception as e:
          print(f"\\n\u274c Error: {e}")
          sys.exit(1)
